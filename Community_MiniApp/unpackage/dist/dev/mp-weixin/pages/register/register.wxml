<view class="register-container data-v-891c2434"><view class="logo-section data-v-891c2434"><text class="app-title data-v-891c2434">用户注册</text><text class="app-subtitle data-v-891c2434">欢迎加入社区便民小程序</text></view><view class="form-section data-v-891c2434"><view class="input-group data-v-891c2434"><text class="input-label data-v-891c2434">账号</text><input class="input-field data-v-891c2434" type="text" placeholder="请输入账号（手机号）" maxlength="11" data-event-opts="{{[['input',[['__set_model',['$0','account','$event',[]],['formData']]]]]}}" value="{{formData.account}}" bindinput="__e"/></view><view class="input-group data-v-891c2434"><text class="input-label data-v-891c2434">所属社区</text><picker mode="selector" range="{{communityList}}" range-key="name" data-event-opts="{{[['change',[['onCommunityChange',['$event']]]]]}}" bindchange="__e" class="data-v-891c2434"><view class="picker-input data-v-891c2434"><text class="{{['data-v-891c2434',formData.communityName?'selected-text':'placeholder-text']}}">{{''+(formData.communityName||'请选择所属社区')+''}}</text><text class="arrow-icon data-v-891c2434">›</text></view></picker></view><view class="input-group data-v-891c2434"><text class="input-label data-v-891c2434">密码</text><input class="input-field data-v-891c2434" type="password" password="{{true}}" placeholder="请输入密码（6-20位）" maxlength="20" data-event-opts="{{[['input',[['__set_model',['$0','password','$event',[]],['formData']]]]]}}" value="{{formData.password}}" bindinput="__e"/></view><view class="input-group data-v-891c2434"><text class="input-label data-v-891c2434">确认密码</text><input class="input-field data-v-891c2434" type="password" password="{{true}}" placeholder="请再次输入密码" maxlength="20" data-event-opts="{{[['input',[['__set_model',['$0','confirmPassword','$event',[]],['formData']]]]]}}" value="{{formData.confirmPassword}}" bindinput="__e"/></view><view class="input-group data-v-891c2434"><text class="input-label data-v-891c2434">验证码</text><view class="captcha-container data-v-891c2434"><input class="captcha-input data-v-891c2434" type="text" placeholder="请输入验证码" maxlength="5" data-event-opts="{{[['input',[['__set_model',['$0','code','$event',[]],['formData']]]]]}}" value="{{formData.code}}" bindinput="__e"/><image class="captcha-image data-v-891c2434" src="{{imgCode}}" mode="aspectFit" data-event-opts="{{[['tap',[['createYzm',['$event']]]]]}}" bindtap="__e"></image></view></view><button data-event-opts="{{[['tap',[['handleRegister',['$event']]]]]}}" class="register-button data-v-891c2434" bindtap="__e">注册</button><view class="login-link-container data-v-891c2434"><text data-event-opts="{{[['tap',[['goToLogin',['$event']]]]]}}" class="login-link data-v-891c2434" bindtap="__e">已有账号？立即登录</text></view></view><view class="footer-section data-v-891c2434"><text class="footer-text data-v-891c2434">社区便民小程序</text><text class="footer-version data-v-891c2434">版本 1.0.0</text></view></view>
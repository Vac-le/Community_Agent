.register-container.data-v-891c2434 {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  height: 100vh;
  padding: 60rpx 40rpx 40rpx;
  background: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  box-sizing: border-box;
  overflow: hidden;
}
/* 顶部标题区域 */
.logo-section.data-v-891c2434 {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 20rpx;
  flex-shrink: 0;
}
.app-title.data-v-891c2434 {
  font-size: 44rpx;
  font-weight: 600;
  color: #303133;
  text-align: center;
  letter-spacing: 1rpx;
  margin-bottom: 15rpx;
}
.app-subtitle.data-v-891c2434 {
  font-size: 28rpx;
  color: #909399;
  text-align: center;
}
/* 注册表单区域 */
.form-section.data-v-891c2434 {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #ffffff;
  padding: 40rpx;
  border-radius: 12rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid #e0e0e0;
  flex: 1;
  overflow-y: auto;
  margin: 20rpx 0;
}
.input-group.data-v-891c2434 {
  width: 100%;
  margin-bottom: 30rpx;
}
.input-label.data-v-891c2434 {
  display: block;
  font-size: 28rpx;
  color: #606266;
  margin-bottom: 12rpx;
  font-weight: 500;
}
.input-field.data-v-891c2434 {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  color: #303133;
  background-color: #ffffff;
  border: 2rpx solid #c0c4cc;
  border-radius: 8rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
}
.input-field.data-v-891c2434:focus {
  border-color: #409eff;
  box-shadow: 0 0 0 2rpx rgba(64, 158, 255, 0.1);
  outline: none;
}
/* 验证码容器 */
.captcha-container.data-v-891c2434 {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.captcha-input.data-v-891c2434 {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  color: #303133;
  background-color: #ffffff;
  border: 2rpx solid #c0c4cc;
  border-radius: 8rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
}
.captcha-input.data-v-891c2434:focus {
  border-color: #409eff;
  box-shadow: 0 0 0 2rpx rgba(64, 158, 255, 0.1);
  outline: none;
}
.captcha-image.data-v-891c2434 {
  width: 260rpx;
  height: 96rpx;
  border: 2rpx solid #c0c4cc;
  border-radius: 8rpx;
  cursor: pointer;
  transition: all 0.2s ease;
}
.captcha-image.data-v-891c2434:active {
  opacity: 0.7;
}
/* 社区选择器 */
.picker-input.data-v-891c2434 {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  background-color: #ffffff;
  border: 2rpx solid #c0c4cc;
  border-radius: 8rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.2s ease;
}
.picker-input.data-v-891c2434:active {
  border-color: #409eff;
}
.placeholder-text.data-v-891c2434 {
  color: #c0c4cc;
}
.selected-text.data-v-891c2434 {
  color: #303133;
}
.arrow-icon.data-v-891c2434 {
  font-size: 40rpx;
  color: #c0c4cc;
  font-weight: bold;
  -webkit-transform: rotate(90deg);
          transform: rotate(90deg);
}
.register-button.data-v-891c2434 {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #ffffff;
  background: #1890ff;
  border: none;
  border-radius: 8rpx;
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.2s ease;
}
.register-button.data-v-891c2434:hover {
  background: #40a9ff;
  -webkit-transform: translateY(-1rpx);
          transform: translateY(-1rpx);
}
/* 登录链接 */
.login-link-container.data-v-891c2434 {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-top: 30rpx;
}
.login-link.data-v-891c2434 {
  font-size: 28rpx;
  color: #1890ff;
  cursor: pointer;
  transition: all 0.2s ease;
}
.login-link.data-v-891c2434:hover {
  color: #40a9ff;
  text-decoration: underline;
}
/* 底部文字信息 */
.footer-section.data-v-891c2434 {
  text-align: center;
  margin-top: 20rpx;
  flex-shrink: 0;
}
.footer-text.data-v-891c2434 {
  font-size: 28rpx;
  color: #606266;
  display: block;
  margin-bottom: 10rpx;
  font-weight: 500;
}
.footer-version.data-v-891c2434 {
  font-size: 24rpx;
  color: #909399;
  display: block;
  font-weight: 400;
}

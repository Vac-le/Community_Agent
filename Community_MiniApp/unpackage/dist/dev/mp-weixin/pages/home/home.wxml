<view class="home-page"><view class="hero-banner"><view class="hero-mask"></view><view class="hero-inner"><text class="hero-kicker">HOME CARE SERVICE</text><text class="hero-title">家政服务</text><text class="hero-desc">专业家政上门，清洁、护理、收纳等服务一键预约</text></view></view><view class="home-body"><view class="filter-card glass-card"><view class="card-header"><view><text class="card-title">服务分类</text><text class="card-subtitle">按服务类型快速筛选，点击卡片查看详情</text></view><text class="count-pill">{{$root.g0+"项"}}</text></view><scroll-view class="category-scroll" scroll-x="{{true}}" show-scrollbar="false"><view class="category-line"><view data-event-opts="{{[['tap',[['selectCategory',['$0'],['allCategory']]]]]}}" class="{{['category-pill',(currentCategory.id===0)?'active':'']}}" bindtap="__e"><text class="pill-emoji">🏠</text><text class="pill-text">全部</text></view><block wx:for="{{$root.l0}}" wx:for-item="category" wx:for-index="__i0__" wx:key="id"><view data-event-opts="{{[['tap',[['selectCategory',['$0'],[[['serviceCategories','id',category.$orig.id]]]]]]]}}" class="{{['category-pill',(currentCategory.id===category.$orig.id)?'active':'']}}" bindtap="__e"><text class="pill-emoji">{{category.m0}}</text><text class="pill-text">{{category.$orig.name}}</text></view></block></view></scroll-view></view><view class="selected-bar glass-card"><text class="selected-label">当前分类</text><text class="selected-name">{{currentCategory.name||'全部服务'}}</text></view><view class="service-section"><view class="section-header"><view><text class="section-title">精选服务</text><text class="section-subtitle">点击查看详情，右下角可快速加入预约清单</text></view></view><block wx:if="{{$root.g1}}"><view class="service-grid"><block wx:for="{{$root.l1}}" wx:for-item="service" wx:for-index="__i1__" wx:key="id"><view data-event-opts="{{[['tap',[['selectService',['$0'],[[['filteredServices','id',service.$orig.id]]]]]]]}}" class="service-card" bindtap="__e"><image class="service-image" src="{{service.$orig.img||defaultServiceImage}}" mode="aspectFill"></image><view class="service-content"><view class="service-top"><text class="service-name">{{service.$orig.name}}</text><text class="service-price">{{"¥"+service.g2}}</text></view><text class="service-tag">{{service.m1}}</text><text class="service-desc">{{service.$orig.description||'专业家政团队上门服务，省时省力更安心。'}}</text></view><view data-event-opts="{{[['tap',[['addToCart',['$0'],[[['filteredServices','id',service.$orig.id]]]]]]]}}" class="add-fab" catchtap="__e"><text class="add-symbol">+</text></view></view></block></view></block><block wx:else><view class="empty-card glass-card"><text class="empty-mark">🧺</text><text class="empty-title">暂无服务</text><text class="empty-tip">当前分类下还没有可展示的家政服务</text></view></block></view></view><block wx:if="{{$root.g3>0}}"><view class="{{['floating-cart',(cartExpanded)?'expanded':'']}}"><view data-event-opts="{{[['tap',[['toggleCart',['$event']]]]]}}" class="cart-summary" bindtap="__e"><view class="cart-main"><view class="cart-badge">{{$root.g4}}</view><view><text class="cart-title">预约清单</text><text class="cart-subtitle">{{"预计金额 ¥"+$root.g5}}</text></view></view><text class="{{['cart-arrow',(cartExpanded)?'rotated':'']}}">⌃</text></view><view hidden="{{!(cartExpanded)}}" class="cart-detail"><view class="delivery-box"><view class="delivery-head"><text class="delivery-title">联系信息</text><text data-event-opts="{{[['tap',[['editContactInfo',['$event']]]]]}}" class="delivery-edit" bindtap="__e">修改</text></view><text class="delivery-line">{{"地址："+(bookingForm.address||'请先设置服务地址')}}</text><text class="delivery-line">{{"电话："+(bookingForm.phone||'请先设置联系电话')}}</text><text class="delivery-line">{{"预约日期："+(bookingForm.date||'请选择上门日期')}}</text></view><view class="cart-items"><block wx:for="{{$root.l2}}" wx:for-item="item" wx:for-index="__i2__" wx:key="id"><view class="cart-item"><view class="cart-item-left"><text class="cart-item-name">{{item.$orig.name}}</text><view class="cart-stepper"><view data-event-opts="{{[['tap',[['decreaseQuantity',['$0'],[[['cartItems','id',item.$orig.id]]]]]]]}}" class="step-btn" catchtap="__e">−</view><text class="step-count">{{item.$orig.quantity}}</text><view data-event-opts="{{[['tap',[['increaseQuantity',['$0'],[[['cartItems','id',item.$orig.id]]]]]]]}}" class="step-btn plus" catchtap="__e">+</view></view></view><text class="cart-item-price">{{"¥"+item.g6}}</text></view></block></view></view><view class="cart-bottom"><text class="cart-total">{{"合计 ¥"+$root.g7}}</text><view data-event-opts="{{[['tap',[['placeOrder',['$event']]]]]}}" class="cart-submit" bindtap="__e">立即预约</view></view></view></block><block wx:if="{{showOrderModal}}"><view data-event-opts="{{[['tap',[['hideOrderModal',['$event']]]]]}}" class="modal-mask" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="order-modal" catchtap="__e"><view class="modal-top"><view><text class="modal-title">确认预约</text><text class="modal-subtitle">请核对服务项目、上门信息与备注</text></view><view data-event-opts="{{[['tap',[['hideOrderModal',['$event']]]]]}}" class="modal-close" bindtap="__e">×</view></view><view class="order-overview"><view class="overview-card"><text class="overview-label">服务数量</text><text class="overview-value">{{$root.g8+"项"}}</text></view><view class="overview-card total-card"><text class="overview-label">预计金额</text><text class="overview-value price">{{"¥"+$root.g9}}</text></view></view><view class="modal-section"><text class="section-caption">服务清单</text><view class="modal-list"><block wx:for="{{$root.l3}}" wx:for-item="item" wx:for-index="__i3__" wx:key="id"><view class="modal-item"><text class="modal-item-name">{{item.$orig.name}}</text><view class="modal-item-right"><text class="modal-item-count">{{"x"+item.$orig.quantity}}</text><text class="modal-item-price">{{"¥"+item.g10}}</text></view></view></block></view></view><view class="modal-section"><text class="section-caption">上门信息</text><view class="field-card"><text class="field-label">预约日期</text><picker mode="date" value="{{bookingForm.date}}" data-event-opts="{{[['change',[['onDateChange',['$event']]]]]}}" bindchange="__e"><view class="picker-box"><text class="{{[bookingForm.date?'picker-text filled':'picker-text']}}">{{bookingForm.date||'请选择服务日期'}}</text><text class="picker-arrow">›</text></view></picker></view><view class="field-card"><text class="field-label">联系电话</text><input class="field-input" type="number" placeholder="请输入联系电话" maxlength="11" data-event-opts="{{[['input',[['__set_model',['$0','phone','$event',[]],['bookingForm']]]]]}}" value="{{bookingForm.phone}}" bindinput="__e"/></view><view class="field-card"><text class="field-label">服务地址</text><textarea class="field-area address-field" placeholder="请输入详细服务地址" maxlength="100" show-confirm-bar="{{false}}" data-event-opts="{{[['input',[['__set_model',['$0','address','$event',[]],['bookingForm']]]]]}}" value="{{bookingForm.address}}" bindinput="__e"></textarea></view></view><view class="modal-section"><text class="section-caption">特殊要求</text><view class="field-card"><textarea class="field-area" placeholder="可填写时间偏好、注意事项等（选填）" maxlength="100" show-confirm-bar="{{false}}" data-event-opts="{{[['input',[['__set_model',['$0','requirements','$event',[]],['bookingForm']]]]]}}" value="{{bookingForm.requirements}}" bindinput="__e"></textarea><text class="remark-count">{{$root.g11+"/100"}}</text></view></view><view class="modal-actions"><view data-event-opts="{{[['tap',[['hideOrderModal',['$event']]]]]}}" class="modal-btn light" bindtap="__e">取消</view><view data-event-opts="{{[['tap',[['confirmOrder',['$event']]]]]}}" class="modal-btn strong" bindtap="__e">确认预约</view></view></view></view></block></view>
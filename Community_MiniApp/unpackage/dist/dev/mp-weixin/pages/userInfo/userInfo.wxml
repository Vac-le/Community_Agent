<view class="container"><view class="header"><text class="header-title">个人资料</text><text data-event-opts="{{[['tap',[['toggleEditMode',['$event']]]]]}}" class="edit-button" bindtap="__e">编辑</text></view><view class="info-card"><view data-event-opts="{{[['tap',[['uploadAvatar',['$event']]]]]}}" class="avatar-section" bindtap="__e"><image class="user-avatar" src="{{userInfo.avatar}}" mode="aspectFill"></image><text class="upload-tip">点击更换头像</text></view><view class="face-image-section"><text class="section-title">人脸识别图片</text><view class="face-image-container"><view data-event-opts="{{[['tap',[['chooseFaceImageSource',['$event']]]]]}}" class="face-image-wrapper" bindtap="__e"><block wx:if="{{userInfo.faceImage}}"><image class="face-image" src="{{userInfo.faceImage}}" mode="aspectFill"></image></block><block wx:else><view class="face-image-placeholder"><text class="placeholder-icon">📷</text><text class="placeholder-text">点击添加人脸图片</text></view></block></view><text class="face-image-tip">用于身份验证，请确保图片清晰</text></view></view><view class="info-form"><view class="form-item"><text class="form-label">姓名:</text><block wx:if="{{isEditMode}}"><view class="form-input-wrapper"><input class="form-input" placeholder="请输入姓名" data-event-opts="{{[['input',[['__set_model',['$0','name','$event',[]],['editForm']]]]]}}" value="{{editForm.name}}" bindinput="__e"/></view></block><block wx:else><text class="form-value">{{userInfo.name}}</text></block></view><view class="form-item"><text class="form-label">性别:</text><block wx:if="{{isEditMode}}"><view class="form-radio-wrapper"><label data-event-opts="{{[['tap',[['selectGender',['男']]]]]}}" class="radio-label" bindtap="__e"><radio value="男" checked="{{editForm.gender==='男'}}"></radio>男</label><label data-event-opts="{{[['tap',[['selectGender',['女']]]]]}}" class="radio-label" bindtap="__e"><radio value="女" checked="{{editForm.gender==='女'}}"></radio>女</label></view></block><block wx:else><text class="form-value">{{userInfo.gender}}</text></block></view><view class="form-item"><text class="form-label">年龄:</text><block wx:if="{{isEditMode}}"><view class="form-input-wrapper"><input class="form-input" type="number" placeholder="请输入年龄" data-event-opts="{{[['input',[['__set_model',['$0','age','$event',['number']],['editForm']]]],['blur',[['$forceUpdate']]]]}}" value="{{editForm.age}}" bindinput="__e" bindblur="__e"/></view></block><block wx:else><text class="form-value">{{userInfo.age+"岁"}}</text></block></view><view class="form-item"><text class="form-label">手机号码:</text><block wx:if="{{isEditMode}}"><view class="form-input-wrapper"><input class="form-input" type="number" placeholder="请输入手机号码" data-event-opts="{{[['input',[['__set_model',['$0','phone','$event',[]],['editForm']]]]]}}" value="{{editForm.phone}}" bindinput="__e"/></view></block><block wx:else><text class="form-value">{{userInfo.phone}}</text></block></view><view class="form-item"><text class="form-label">联系地址:</text><block wx:if="{{isEditMode}}"><view class="form-input-wrapper"><input class="form-input" placeholder="请输入联系地址" data-event-opts="{{[['input',[['__set_model',['$0','address','$event',[]],['editForm']]]]]}}" value="{{editForm.address}}" bindinput="__e"/></view></block><block wx:else><text class="form-value">{{userInfo.address}}</text></block></view></view><block wx:if="{{isEditMode}}"><view class="button-section"><button data-event-opts="{{[['tap',[['cancelEdit',['$event']]]]]}}" class="cancel-button" bindtap="__e">取消</button><button class="save-button" type="primary" data-event-opts="{{[['tap',[['saveUserInfo',['$event']]]]]}}" bindtap="__e">保存</button></view></block></view><view class="notice-section"><text class="notice-title">温馨提示</text><text class="notice-content">1. 请确保个人信息真实有效，以便我们为您提供更好的服务
2. 如有特殊健康状况，请在健康档案中详细说明</text></view></view>
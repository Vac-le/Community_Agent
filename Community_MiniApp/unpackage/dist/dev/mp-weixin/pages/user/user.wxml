<view class="container"><view class="user-section"><view class="user-profile"><image class="avatar" src="{{userInfo.avatar}}" mode="aspectFill"></image><view class="user-detail"><text class="username">{{userInfo.name||'用户'}}</text><view class="user-tags"><text class="tag">{{"ID "+userInfo.id}}</text><text class="tag-dot"></text><text class="tag">{{userInfo.age+"岁"}}</text></view></view></view><view class="stats-row"><view data-event-opts="{{[['tap',[['myOrders',['$event']]]]]}}" class="stat-item" bindtap="__e"><text class="stat-num">{{orderStats.allCount||0}}</text><text class="stat-text">全部</text></view><view class="stat-divider"></view><view data-event-opts="{{[['tap',[['myOrders',['$event']]]]]}}" class="stat-item" bindtap="__e"><text class="stat-num">{{orderStats.waitCount||0}}</text><text class="stat-text">待服务</text></view><view class="stat-divider"></view><view data-event-opts="{{[['tap',[['myOrders',['$event']]]]]}}" class="stat-item" bindtap="__e"><text class="stat-num">{{orderStats.completeCount||0}}</text><text class="stat-text">已完成</text></view></view></view><block wx:if="{{todayWeather}}"><view class="weather-section"><view class="weather-header"><view class="location-info"><text class="location-icon">📍</text><text class="city-name">{{cityInfo.cityName}}</text></view></view><view class="today-weather"><view class="weather-main"><view class="temp-area"><text class="temp-now">{{todayWeather.tempDay+"°"}}</text><text class="temp-range">{{todayWeather.tempNight+"° ~ "+todayWeather.tempDay+"°"}}</text></view><view class="weather-desc"><text class="condition-text">{{todayWeather.conditionDay}}</text><block wx:if="{{todayWeather.humidity}}"><text class="humidity-text">{{"湿度 "+todayWeather.humidity+"%"}}</text></block></view></view><view class="weather-details"><block wx:if="{{todayWeather.windDirDay}}"><view class="detail-item"><text class="detail-icon">💨</text><text class="detail-text">{{todayWeather.windDirDay+" "+todayWeather.windLevelDay+"级"}}</text></view></block><block wx:if="{{todayWeather.pop}}"><view class="detail-item"><text class="detail-icon">💧</text><text class="detail-text">{{"降水 "+todayWeather.pop+"%"}}</text></view></block><block wx:if="{{todayWeather.uvi}}"><view class="detail-item"><text class="detail-icon">☀️</text><text class="detail-text">{{"紫外线 "+todayWeather.uvi}}</text></view></block><block wx:if="{{!todayWeather.pop&&todayWeather.windSpeedDay}}"><view class="detail-item"><text class="detail-icon">💨</text><text class="detail-text">{{"风速 "+todayWeather.windSpeedDay+"m/s"}}</text></view></block></view></view><block wx:if="{{$root.g0>0}}"><scroll-view class="forecast-scroll" scroll-x="{{true}}"><view class="forecast-list"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="forecast-item"><text class="forecast-date">{{item.m0}}</text><text class="forecast-icon">{{item.m1}}</text><text class="forecast-condition">{{item.$orig.conditionDay}}</text><text class="forecast-temp">{{item.$orig.tempNight+"°~"+item.$orig.tempDay+"°"}}</text></view></block></view></scroll-view></block></view></block><block wx:if="{{$root.g1>0}}"><view class="menu-section"><view class="menu-list"><block wx:for="{{menus}}" wx:for-item="menu" wx:for-index="index" wx:key="index"><view class="menu-item" data-index="{{index}}" data-event-opts="{{[['tap',[['handleMenuClick',['$event']]]]]}}" bindtap="__e"><text class="menu-text">{{menu.name}}</text><text class="menu-arrow">›</text></view></block></view></view></block><view class="menu-section"><view data-event-opts="{{[['tap',[['callHotline',['$event']]]]]}}" class="hotline-item" bindtap="__e"><view class="hotline-left"><text class="hotline-label">社区服务热线</text><text class="hotline-number">400-123-4567</text></view><text class="call-text">拨打</text></view></view><view class="logout-section"><text data-event-opts="{{[['tap',[['logout',['$event']]]]]}}" class="logout-btn" bindtap="__e">退出登录</text></view><view class="bottom-space"></view></view>
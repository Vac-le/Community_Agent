}
.left-categories .category-item {
  padding: 35rpx 15rpx;
  text-align: center;
  background: #f5f5f5;
  border-bottom: 1rpx solid #e0e0e0;
}
.left-categories .category-item.active {
  background: #ffffff;
}
.right-food-list {
  flex: 1;
  overflow-y: auto;
  background: #ffffff;
}
.food-items {
  display: flex;
  flex-direction: column;
}
.food-item {
  background: #ffffff;
  padding: 25rpx 20rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
}
.food-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.food-details {
  flex: 1;
  min-width: 0;
}
.food-name {
  font-size: 30rpx;
  margin-bottom: 8rpx;
  color: #333;
  font-weight: 600;
}
.food-desc {
  font-size: 24rpx;
  margin-bottom: 12rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.food-price {
  display: flex;
  align-items: baseline;
}
.unit {
  font-size: 22rpx;
  color: #999;
  margin-left: 4rpx;
}
.add-button {
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
  border: none;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 15rpx;
  flex-shrink: 0;
}
.add-text {
  color: #ffffff;
  font-size: 36rpx;
  line-height: 1;
}
/* ========== 代购服务 purchases.vue ========== */
.purchases-container {
  background: #fafafa;
  min-height: 100vh;
  padding-bottom: 200rpx;
}
.product-categories {
  margin: 40rpx 30rpx 30rpx;
}
.product-list {
  margin: 0 30rpx 30rpx;
}
.product-items {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.product-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
  border: 2rpx solid #e0e0e0;
}
.product-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 15rpx;
  margin-right: 20rpx;
}
.product-details {
  flex: 1;
}
.product-name {
  font-size: 28rpx;
  margin-bottom: 5rpx;
  color: #2d3436;
  font-weight: 600;
}
.product-desc {
  font-size: 24rpx;
  margin-bottom: 10rpx;
  color: #636e72;
}
.product-price {
  display: flex;
  align-items: baseline;
}
.cart {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 25rpx 25rpx 0 0;
  padding: 25rpx 30rpx 30rpx;
  box-shadow: 0 -8rpx 25rpx rgba(0, 0, 0, 0.1);
  z-index: 1000;
}
.modal-content {
  background: #fff;
  border-radius: 25rpx;
}
@media (max-width: 750rpx) {
.category-grid {
    grid-template-columns: repeat(3, 1fr);
}
.service-grid {
    grid-template-columns: 1fr;
}
}

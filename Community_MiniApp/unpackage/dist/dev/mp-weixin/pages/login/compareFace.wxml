<view class="face-login-container data-v-1e4baa13"><view class="header-section data-v-1e4baa13"><text class="title data-v-1e4baa13">人脸识别登录</text><text class="subtitle data-v-1e4baa13">请拍摄或上传您的正面照片</text></view><view class="phone-section data-v-1e4baa13"><view class="input-wrapper data-v-1e4baa13"><text class="input-label data-v-1e4baa13">手机号码</text><input class="phone-input data-v-1e4baa13" type="number" placeholder="请输入您的手机号码" maxlength="11" data-event-opts="{{[['input',[['__set_model',['','phoneNumber','$event',[]]]]]]}}" value="{{phoneNumber}}" bindinput="__e"/></view></view><view class="photo-section data-v-1e4baa13"><block wx:if="{{!photoPath}}"><view data-event-opts="{{[['tap',[['showActionSheet',['$event']]]]]}}" class="photo-placeholder data-v-1e4baa13" bindtap="__e"><text class="placeholder-icon data-v-1e4baa13">📷</text><text class="placeholder-text data-v-1e4baa13">点击拍照或选择照片</text></view></block><block wx:else><view class="photo-preview data-v-1e4baa13"><image class="preview-image data-v-1e4baa13" src="{{photoPath}}" mode="aspectFit"></image><view class="photo-actions data-v-1e4baa13"><text data-event-opts="{{[['tap',[['showActionSheet',['$event']]]]]}}" class="action-btn data-v-1e4baa13" bindtap="__e">重新拍摄</text></view></view></block></view><view class="tips-section data-v-1e4baa13"><text class="tips-title data-v-1e4baa13">📋 温馨提示</text><text class="tips-item data-v-1e4baa13">• 请保持光线充足</text><text class="tips-item data-v-1e4baa13">• 请正面拍摄，露出完整五官</text><text class="tips-item data-v-1e4baa13">• 请摘下口罩、墨镜等遮挡物</text></view><view class="button-section data-v-1e4baa13"><button class="submit-btn data-v-1e4baa13" disabled="{{!photoPath||!phoneNumber||isLoading}}" data-event-opts="{{[['tap',[['handleFaceLogin',['$event']]]]]}}" bindtap="__e">{{''+(isLoading?'识别中...':'开始识别')+''}}</button><button data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="back-btn data-v-1e4baa13" bindtap="__e">返回登录</button></view></view>
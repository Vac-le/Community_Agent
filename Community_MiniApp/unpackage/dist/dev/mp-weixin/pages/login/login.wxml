<view class="login-container"><view class="auth-card"><view class="title-wrap"><text class="title-main">智慧社区</text></view><view class="form-section"><view class="input-row"><text class="input-icon">👤</text><input class="input-field" type="number" placeholder="User name" data-event-opts="{{[['input',[['__set_model',['','phoneNumber','$event',[]]]]]]}}" value="{{phoneNumber}}" bindinput="__e"/></view><view class="input-row"><text class="input-icon">🔒</text><input class="input-field" type="password" password="{{true}}" placeholder="Password" data-event-opts="{{[['input',[['__set_model',['','password','$event',[]]]]]]}}" value="{{password}}" bindinput="__e"/></view><view class="forgot-wrap"><text data-event-opts="{{[['tap',[['goToRegister',['$event']]]]]}}" class="forgot-text" bindtap="__e">注册账号</text></view><button data-event-opts="{{[['tap',[['phoneLogin',['$event']]]]]}}" class="login-button" bindtap="__e">登录</button><view class="face-wrap"><text data-event-opts="{{[['tap',[['goFaceLogin',['$event']]]]]}}" class="face-link" bindtap="__e">人脸识别登录</text></view></view></view></view>
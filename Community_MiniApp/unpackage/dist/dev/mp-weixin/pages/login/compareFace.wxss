














































































































































































































































































/* 整体容器 */
.face-login-container.data-v-1e4baa13 {
  min-height: 100vh;
  background: linear-gradient(to bottom, #f0f2f5 0%, #ffffff 100%);
  padding: 40rpx;
  box-sizing: border-box;
}
/* 顶部标题 */
.header-section.data-v-1e4baa13 {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}
.title.data-v-1e4baa13 {
  font-size: 44rpx;
  font-weight: 700;
  color: #303133;
  margin-bottom: 16rpx;
}
.subtitle.data-v-1e4baa13 {
  font-size: 26rpx;
  color: #909399;
}
/* 照片区域 */
.photo-section.data-v-1e4baa13 {
  width: 100%;
  margin-bottom: 50rpx;
}
.photo-placeholder.data-v-1e4baa13 {
  width: 100%;
  height: 500rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 3rpx dashed #d9d9d9;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}
.photo-placeholder.data-v-1e4baa13:active {
  -webkit-transform: scale(0.98);
          transform: scale(0.98);
  border-color: #1890ff;
}
.placeholder-icon.data-v-1e4baa13 {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}
.placeholder-text.data-v-1e4baa13 {
  font-size: 28rpx;
  color: #909399;
}
.photo-preview.data-v-1e4baa13 {
  width: 100%;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}
.preview-image.data-v-1e4baa13 {
  width: 100%;
  height: 500rpx;
}
.photo-actions.data-v-1e4baa13 {
  padding: 20rpx;
  text-align: center;
  border-top: 1rpx solid #f0f0f0;
}
.action-btn.data-v-1e4baa13 {
  font-size: 28rpx;
  color: #1890ff;
  padding: 10rpx 20rpx;
}
/* 手机号输入区域 */
.phone-section.data-v-1e4baa13 {
  margin-bottom: 40rpx;
}
.input-wrapper.data-v-1e4baa13 {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid #f0f0f0;
  transition: all 0.3s ease;
}
.input-wrapper.data-v-1e4baa13:focus-within {
  border-color: #1890ff;
  box-shadow: 0 2rpx 12rpx rgba(24, 144, 255, 0.15);
}
.input-label.data-v-1e4baa13 {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 16rpx;
}
.phone-input.data-v-1e4baa13 {
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  color: #303133;
  background: #f8f9fa;
  border: 2rpx solid #e9ecef;
  border-radius: 8rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  transition: all 0.3s ease;
}
.phone-input.data-v-1e4baa13:focus {
  background: #ffffff;
  border-color: #1890ff;
  outline: none;
}
.phone-input.data-v-1e4baa13::-webkit-input-placeholder {
  color: #909399;
  font-size: 28rpx;
}
.phone-input.data-v-1e4baa13::placeholder {
  color: #909399;
  font-size: 28rpx;
}
/* 温馨提示 */
.tips-section.data-v-1e4baa13 {
  background: #fffbe6;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 50rpx;
  border-left: 4rpx solid #faad14;
}
.tips-title.data-v-1e4baa13 {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 16rpx;
}
.tips-item.data-v-1e4baa13 {
  display: block;
  font-size: 26rpx;
  color: #606266;
  line-height: 2;
  margin-left: 20rpx;
}
/* 按钮区域 */
.button-section.data-v-1e4baa13 {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.submit-btn.data-v-1e4baa13 {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1890ff 0%, #0c7cd5 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(24, 144, 255, 0.35);
  transition: all 0.3s ease;
}
.submit-btn.data-v-1e4baa13:active {
  -webkit-transform: scale(0.98);
          transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.25);
}
.submit-btn[disabled].data-v-1e4baa13 {
  opacity: 0.6;
}
.back-btn.data-v-1e4baa13 {
  width: 100%;
  height: 88rpx;
  background: #ffffff;
  color: #606266;
  font-size: 28rpx;
  border-radius: 44rpx;
  border: 2rpx solid #d9d9d9;
  transition: all 0.3s ease;
}
.back-btn.data-v-1e4baa13:active {
  background: #f5f5f5;
  -webkit-transform: scale(0.98);
          transform: scale(0.98);
}
/* ========== 全局统一主题覆盖（人脸登录） ========== */
.face-login-container.data-v-1e4baa13 {
  background:
    radial-gradient(circle at 16% 10%, rgba(122, 163, 255, 0.3) 0%, rgba(122, 163, 255, 0) 35%),
    linear-gradient(145deg, #e8efff 0%, #dce8ff 100%) !important;
}
.input-wrapper.data-v-1e4baa13,
.photo-placeholder.data-v-1e4baa13,
.photo-preview.data-v-1e4baa13,
.tips-section.data-v-1e4baa13,
.phone-input.data-v-1e4baa13 {
  background: #edf3ff !important;
  border: 1rpx solid rgba(255,255,255,0.78) !important;
  box-shadow: 12rpx 12rpx 24rpx rgba(128,151,199,0.22), -12rpx -12rpx 24rpx rgba(255,255,255,0.95) !important;
}
.title.data-v-1e4baa13,
.input-label.data-v-1e4baa13,
.tips-title.data-v-1e4baa13 {
  color: #334f7c !important;
}
.subtitle.data-v-1e4baa13,
.placeholder-text.data-v-1e4baa13,
.tips-item.data-v-1e4baa13 {
  color: #7890b4 !important;
}
.phone-input.data-v-1e4baa13 {
  height: 84rpx !important;
  font-size: 30rpx !important;
  padding: 0 22rpx !important;
  border-radius: 18rpx !important;
}
.submit-btn.data-v-1e4baa13,
.back-btn.data-v-1e4baa13 {
  height: 84rpx !important;
  border-radius: 999rpx !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  line-height: 1 !important;
}
.submit-btn.data-v-1e4baa13 {
  background: linear-gradient(145deg, #84a7ff 0%, #5f86ff 100%) !important;
}
.back-btn.data-v-1e4baa13 {
  background: #edf3ff !important;
  color: #5975a3 !important;
}


<view class="container"><view class="particles-bg"><block wx:for="{{particles}}" wx:for-item="p" wx:for-index="i" wx:key="i"><view class="particle" style="{{(p.style)}}"></view></block></view><swiper class="banner" indicator-dots="{{true}}" circular="{{true}}" autoplay="{{true}}" interval="3000"><swiper-item><image src="/static/首页图片.png" mode="aspectFill"></image></swiper-item><swiper-item><image src="https://img95.699pic.com/photo/40245/5493.jpg_wh300.jpg" mode="aspectFill"></image></swiper-item><swiper-item><image src="https://imgs.699pic.com/images/501/280/316.jpg!list1x.v2" mode="aspectFill"></image></swiper-item></swiper><view class="quick-services"><text class="section-title">服务</text><view class="service-grid"><block wx:for="{{menus}}" wx:for-item="m" wx:for-index="index" wx:key="id"><view class="service-item"><navigator class="service-navigator" url="{{m.url}}" open-type="navigate"><view class="service-icon"><image class="service-image" src="{{m.img}}" mode="aspectFit" alt="{{m.name}}"></image></view><text class="service-name">{{m.name}}</text></navigator></view></block></view></view><block wx:if="{{todayWeather}}"><view class="weather-section"><view class="weather-header"><view class="location-info"><text class="location-icon">📍</text><text class="city-name">{{cityInfo.cityName}}</text></view></view><view class="today-weather"><view class="weather-main"><view class="temp-area"><text class="temp-now">{{todayWeather.tempDay+"°"}}</text><text class="temp-range">{{todayWeather.tempNight+"° ~ "+todayWeather.tempDay+"°"}}</text></view><view class="weather-desc"><text class="condition-text">{{todayWeather.conditionDay}}</text><block wx:if="{{todayWeather.humidity}}"><text class="humidity-text">{{"湿度 "+todayWeather.humidity+"%"}}</text></block></view></view><view class="weather-details"><block wx:if="{{todayWeather.windDirDay}}"><view class="detail-item"><text class="detail-icon">💨</text><text class="detail-text">{{todayWeather.windDirDay+" "+todayWeather.windLevelDay+"级"}}</text></view></block><block wx:if="{{todayWeather.pop}}"><view class="detail-item"><text class="detail-icon">💧</text><text class="detail-text">{{"降水 "+todayWeather.pop+"%"}}</text></view></block><block wx:if="{{todayWeather.uvi}}"><view class="detail-item"><text class="detail-icon">☀️</text><text class="detail-text">{{"紫外线 "+todayWeather.uvi}}</text></view></block><block wx:if="{{!todayWeather.pop&&todayWeather.windSpeedDay}}"><view class="detail-item"><text class="detail-icon">💨</text><text class="detail-text">{{"风速 "+todayWeather.windSpeedDay+"m/s"}}</text></view></block></view></view></view></block><view class="latest-activities"><text class="section-title">最新活动</text><view class="activity-list"><block wx:for="{{activities}}" wx:for-item="item" wx:for-index="index" wx:key="id"><view data-event-opts="{{[['tap',[['showActivityDetail',['$0'],[[['activities','id',item.id]]]]]]]}}" class="activity-item" bindtap="__e"><image class="activity-image" src="{{item.img}}" mode="aspectFill"></image><view class="activity-info"><text class="activity-title">{{item.title}}</text><text class="activity-time">{{item.oper_time}}</text></view></view></block></view></view><view class="announcements"><text class="section-title">社区公告</text><view class="announcement-list"><block wx:for="{{announcements}}" wx:for-item="item" wx:for-index="index" wx:key="id"><view data-event-opts="{{[['tap',[['showNoticeDetail',['$0'],[[['announcements','id',item.id]]]]]]]}}" class="announcement-item" bindtap="__e"><text class="announcement-title">{{item.title}}</text><text class="announcement-time">{{item.oper_time}}</text></view></block></view></view><block wx:if="{{showActivityPopup}}"><view data-event-opts="{{[['tap',[['closeActivityPopup',['$event']]]]]}}" class="popup-mask" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="popup-content" catchtap="__e"><view class="popup-header"><text class="popup-title">{{selectedActivity.title}}</text><view data-event-opts="{{[['tap',[['closeActivityPopup',['$event']]]]]}}" class="popup-close" bindtap="__e"><text class="close-icon">×</text></view></view><scroll-view class="popup-scroll" scroll-y="{{true}}"><view class="popup-time"><text class="time-label">发布时间：</text><text class="time-value">{{selectedActivity.operTime}}</text></view><block wx:if="{{selectedActivity.img}}"><view class="popup-image"><image class="detail-image" src="{{selectedActivity.img}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$0'],['selectedActivity.img']]]]]}}" bindtap="__e"></image></view></block><view class="popup-body"><rich-text class="rich-content" nodes="{{processedContent}}"></rich-text></view></scroll-view></view></view></block><block wx:if="{{showNoticePopup}}"><view data-event-opts="{{[['tap',[['closeNoticePopup',['$event']]]]]}}" class="popup-mask" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="popup-content" catchtap="__e"><view class="popup-header"><text class="popup-title">{{selectedNotice.title}}</text><view data-event-opts="{{[['tap',[['closeNoticePopup',['$event']]]]]}}" class="popup-close" bindtap="__e"><text class="close-icon">×</text></view></view><scroll-view class="popup-scroll" scroll-y="{{true}}"><view class="popup-time"><text class="time-label">发布时间：</text><text class="time-value">{{selectedNotice.operTime}}</text></view><view class="popup-body"><text class="notice-content">{{selectedNotice.content}}</text></view></scroll-view></view></view></block></view>
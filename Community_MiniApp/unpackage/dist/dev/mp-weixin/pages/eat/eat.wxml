<view class="eat-page"><view class="hero-banner"><view class="hero-mask"></view><view class="hero-inner"><text class="hero-kicker">COMMUNITY DINING</text><text class="hero-title">餐饮服务</text><text class="hero-desc">社区食堂每日供应，现做现送，健康又省心</text></view></view><view class="eat-body"><view class="filter-card glass-card"><view class="card-header"><view><text class="card-title">菜品分类</text><text class="card-subtitle">切换分类后，右侧菜品会即时筛选</text></view><text class="count-pill">{{$root.g0+"款"}}</text></view><scroll-view class="category-scroll" scroll-x="{{true}}" show-scrollbar="false"><view class="category-line"><view data-event-opts="{{[['tap',[['selectCategory',['$0'],['all']]]]]}}" class="{{['category-pill',(currentCategory.id===0)?'active':'']}}" bindtap="__e"><text class="pill-emoji">🍽</text><text class="pill-text">全部</text></view><block wx:for="{{$root.l0}}" wx:for-item="category" wx:for-index="__i0__" wx:key="id"><view data-event-opts="{{[['tap',[['selectCategory',['$0'],[[['foodTypes','id',category.$orig.id]]]]]]]}}" class="{{['category-pill',(currentCategory.id===category.$orig.id)?'active':'']}}" bindtap="__e"><text class="pill-emoji">{{category.m0}}</text><text class="pill-text">{{category.$orig.name}}</text></view></block></view></scroll-view></view><view class="selected-bar glass-card"><text class="selected-label">当前分类</text><text class="selected-name">{{currentCategory.name||'全部菜品'}}</text></view><view class="food-section"><view class="section-header"><view><text class="section-title">今日菜品</text><text class="section-subtitle">点击查看详情，点击加号可快速加入购物车</text></view></view><block wx:if="{{$root.g1}}"><view class="food-grid"><block wx:for="{{$root.l1}}" wx:for-item="food" wx:for-index="__i1__" wx:key="id"><view data-event-opts="{{[['tap',[['selectFood',['$0'],[[['filteredFoods','id',food.$orig.id]]]]]]]}}" class="food-card" bindtap="__e"><image class="food-image" src="{{food.$orig.img||defaultFoodImage}}" mode="aspectFill"></image><view class="food-content"><view class="food-top"><text class="food-name">{{food.$orig.name}}</text><text class="food-price">{{"¥"+food.g2}}</text></view><text class="food-tag">{{food.m1}}</text><text class="food-desc">{{food.$orig.description||'社区精选菜品，口味稳定，适合日常订餐。'}}</text></view><view data-event-opts="{{[['tap',[['addToCart',['$0'],[[['filteredFoods','id',food.$orig.id]]]]]]]}}" class="add-fab" catchtap="__e"><text class="add-symbol">+</text></view></view></block></view></block><block wx:else><view class="empty-card glass-card"><text class="empty-mark">🍲</text><text class="empty-title">暂无菜品</text><text class="empty-tip">当前分类下还没有可展示的菜品</text></view></block></view></view><block wx:if="{{$root.g3>0}}"><view class="{{['floating-cart',(cartExpanded)?'expanded':'']}}"><view data-event-opts="{{[['tap',[['toggleCart',['$event']]]]]}}" class="cart-summary" bindtap="__e"><view class="cart-main"><view class="cart-badge">{{$root.g4}}</view><view><text class="cart-title">购物车</text><text class="cart-subtitle">{{"总计 ¥"+$root.g5}}</text></view></view><text class="{{['cart-arrow',(cartExpanded)?'rotated':'']}}">⌃</text></view><view hidden="{{!(cartExpanded)}}" class="cart-detail"><view class="delivery-box"><view class="delivery-head"><text class="delivery-title">配送信息</text><text data-event-opts="{{[['tap',[['editDeliveryInfo',['$event']]]]]}}" class="delivery-edit" bindtap="__e">修改</text></view><text class="delivery-line">{{"地址："+(deliveryAddress||'请先设置配送地址')}}</text><text class="delivery-line">{{"电话："+(deliveryPhone||'请先设置联系电话')}}</text></view><view class="cart-items"><block wx:for="{{$root.l2}}" wx:for-item="item" wx:for-index="__i2__" wx:key="id"><view class="cart-item"><view class="cart-item-left"><text class="cart-item-name">{{item.$orig.name}}</text><view class="cart-stepper"><view data-event-opts="{{[['tap',[['decreaseQuantity',['$0'],[[['cartItems','id',item.$orig.id]]]]]]]}}" class="step-btn" catchtap="__e">−</view><text class="step-count">{{item.$orig.quantity}}</text><view data-event-opts="{{[['tap',[['increaseQuantity',['$0'],[[['cartItems','id',item.$orig.id]]]]]]]}}" class="step-btn plus" catchtap="__e">+</view></view></view><text class="cart-item-price">{{"¥"+item.g6}}</text></view></block></view></view><view class="cart-bottom"><text class="cart-total">{{"合计 ¥"+$root.g7}}</text><view data-event-opts="{{[['tap',[['placeOrder',['$event']]]]]}}" class="cart-submit" bindtap="__e">立即下单</view></view></view></block><block wx:if="{{showOrderModal}}"><view data-event-opts="{{[['tap',[['hideOrderModal',['$event']]]]]}}" class="modal-mask" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="order-modal" catchtap="__e"><view class="modal-top"><view><text class="modal-title">确认下单</text><text class="modal-subtitle">请核对菜品、配送信息与备注</text></view><view data-event-opts="{{[['tap',[['hideOrderModal',['$event']]]]]}}" class="modal-close" bindtap="__e">×</view></view><view class="order-overview"><view class="overview-card"><text class="overview-label">商品件数</text><text class="overview-value">{{$root.g8+"件"}}</text></view><view class="overview-card total-card"><text class="overview-label">订单金额</text><text class="overview-value price">{{"¥"+$root.g9}}</text></view></view><view class="modal-section"><text class="section-caption">商品清单</text><view class="modal-list"><block wx:for="{{$root.l3}}" wx:for-item="item" wx:for-index="__i3__" wx:key="id"><view class="modal-item"><text class="modal-item-name">{{item.$orig.name}}</text><view class="modal-item-right"><text class="modal-item-count">{{"x"+item.$orig.quantity}}</text><text class="modal-item-price">{{"¥"+item.g10}}</text></view></view></block></view></view><view class="modal-section"><text class="section-caption">配送信息</text><view class="field-card"><text class="field-label">配送地址</text><textarea class="field-area address-field" placeholder="请输入配送地址" maxlength="100" show-confirm-bar="{{false}}" data-event-opts="{{[['input',[['__set_model',['','deliveryAddress','$event',[]]]]]]}}" value="{{deliveryAddress}}" bindinput="__e"></textarea></view><view class="field-card"><text class="field-label">联系电话</text><input class="field-input" type="number" placeholder="请输入联系电话" maxlength="11" data-event-opts="{{[['input',[['__set_model',['','deliveryPhone','$event',[]]]]]]}}" value="{{deliveryPhone}}" bindinput="__e"/></view></view><view class="modal-section"><text class="section-caption">订单备注</text><view class="field-card"><textarea class="field-area" placeholder="请输入口味偏好、少辣少盐等备注（选填）" maxlength="100" show-confirm-bar="{{false}}" data-event-opts="{{[['input',[['__set_model',['','orderRemark','$event',[]]]]]]}}" value="{{orderRemark}}" bindinput="__e"></textarea><text class="remark-count">{{$root.g11+"/100"}}</text></view></view><view class="modal-actions"><view data-event-opts="{{[['tap',[['hideOrderModal',['$event']]]]]}}" class="modal-btn light" bindtap="__e">取消</view><view data-event-opts="{{[['tap',[['confirmOrder',['$event']]]]]}}" class="modal-btn strong" bindtap="__e">确认下单</view></view></view></view></block></view>
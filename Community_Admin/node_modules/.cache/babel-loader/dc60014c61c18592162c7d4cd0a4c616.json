","sourcesContent":["<template>\n  <div>\n    <el-dialog\n      title=\"添加家政服务\"\n      :visible.sync=\"dialogVisible\"\n      width=\"600px\"\n      class=\"modern-dialog fixed-dialog\"\n      :modal=\"false\"\n    >\n      <el-form\n        ref=\"form\"\n        :model=\"form\"\n        :rules=\"rules\"\n        label-width=\"100px\"\n        class=\"modern-form\"\n      >\n        <!-- 服务名称 -->\n        <el-form-item label=\"服务名称:\" prop=\"name\" class=\"field-full\">\n          <el-input v-model=\"form.name\" placeholder=\"请输入服务名称\"></el-input>\n        </el-form-item>\n\n        <!-- 服务类型 -->\n        <el-form-item label=\"服务类型:\" prop=\"homeTypeId\" class=\"field-full\">\n          <el-select\n            v-model=\"form.homeTypeId\"\n            placeholder=\"请选择服务类型\"\n            style=\"width: 100%\"\n          >\n            <el-option\n              v-for=\"type in homeTypes\"\n              :key=\"type.id\"\n              :label=\"type.name\"\n              :value=\"type.id\"\n            ></el-option>\n          </el-select>\n        </el-form-item>\n\n        <!-- 服务价格 -->\n        <el-form-item label=\"服务价格:\" prop=\"price\" class=\"field-full\">\n          <el-input-number\n            v-model=\"form.price\"\n            :min=\"0\"\n            :precision=\"0\"\n            :step=\"1\"\n            placeholder=\"请输入服务价格（整数）\"\n            style=\"width: 100%\"\n          ></el-input-number>\n        </el-form-item>\n\n        <!-- 服务描述 -->\n        <el-form-item label=\"服务描述:\" prop=\"description\" class=\"field-full\">\n          <el-input\n            type=\"textarea\"\n            v-model=\"form.description\"\n            :rows=\"4\"\n            placeholder=\"请输入服务描述\"\n            maxlength=\"200\"\n           \n          ></el-input>\n        </el-form-item>\n\n        <!-- 服务图片 -->\n        <el-form-item label=\"服务图片:\" class=\"field-full\">\n          <el-upload\n            class=\"avatar-uploader\"\n            :action=\"uploadUrl\"\n            :show-file-list=\"false\"\n            :on-success=\"handleUploadSuccess\"\n            :before-upload=\"beforeUpload\"\n            :headers=\"uploadHeaders\"\n          >\n            <img v-if=\"imageUrl\" :src=\"imageUrl\" class=\"avatar\" />\n            <i v-else class=\"el-icon-plus avatar-uploader-icon\"></i>\n          </el-upload>\n          <div class=\"upload-tip\">支持 jpg、png 格式，大小不超过 2MB</div>\n        </el-form-item>\n      </el-form>\n      <span slot=\"footer\" class=\"dialog-footer modern-dialog-footer\">\n        <el-button type=\"warning\" @click=\"dialogVisible = false\" class=\"btn-cancel\">取 消</el-button>\n        <el-button type=\"primary\" @click=\"addHome\" class=\"btn-submit\">保 存</el-button>\n      </span>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      dialogVisible: false,\n      form: {\n        name: \"\",\n        homeTypeId: \"\",\n        price: 0,\n        description: \"\",\n        img: \"\"\n      },\n      homeTypes: [],\n      imageUrl: \"\",\n      uploadUrl: this.$http.defaults.baseURL + \"api/productCtl/uploadImg\",\n      uploadHeaders: {\n        token: sessionStorage.getItem(\"token\")\n      },\n      rules: {\n        name: [\n          { required: true, message: \"请输入服务名称\", trigger: \"blur\" },\n          { min: 2, max: 50, message: \"长度在 2 到 50 个字符\", trigger: \"blur\" }\n        ],\n        homeTypeId: [\n          { required: true, message: \"请选择服务类型\", trigger: \"change\" }\n        ],\n        price: [\n          { required: true, message: \"请输入服务价格\", trigger: \"blur\" }\n        ]\n      }\n    };\n  },\n  methods: {\n    // 加载家政服务类型列表\n    loadHomeTypes() {\n      this.$http.get(\"/api/productCtl/homeTypeList\").then(resp => {\n        if (resp.data.code === 200) {\n          this.homeTypes = resp.data.data;\n        }\n      });\n    },\n\n    // 上传前验证\n    beforeUpload(file) {\n      const isImage = file.type === \"image/jpeg\" || file.type === \"image/png\";\n      const isLt2M = file.size / 1024 / 1024 < 2;\n\n      if (!isImage) {\n        this.$message.error(\"只能上传 JPG/PNG 格式的图片!\");\n      }\n      if (!isLt2M) {\n        this.$message.error(\"上传图片大小不能超过 2MB!\");\n      }\n      return isImage && isLt2M;\n    },\n\n    // 上传成功回调\n    handleUploadSuccess(response) {\n      if (response.code === 200) {\n        this.imageUrl = response.data;\n        this.form.img = response.data;\n        this.$message.success(\"图片上传成功\");\n      } else {\n        this.$message.error(\"图片上传失败: \" + response.msg);\n      }\n    },\n\n    // 添加家政服务\n    addHome() {\n      this.$refs.form.validate(valid => {\n        if (valid) {\n          this.$http\n            .post(\"/api/productCtl/addHome\", this.form)\n            .then(resp => {\n              if (resp.data.code === 200) {\n                this.$message({\n                  message: \"添加成功\",\n                  type: \"success\",\n                  duration: 1000,\n                  onClose: () => {\n                    this.dialogVisible = false;\n                    this.resetForm();\n                    this.$emit(\"refresh\");\n                  }\n                });\n              } else {\n                this.$message({\n                  type: \"error\",\n                  message: resp.data.msg || \"添加失败\",\n                  duration: 2000\n                });\n              }\n            })\n            .catch(() => {\n              this.$message({\n                type: \"error\",\n                message: \"添加家政服务失败，请重试\",\n                duration: 2000\n              });\n            });\n        } else {\n          this.$message.error(\"请填写完整信息\");\n        }\n      });\n    },\n\n    // 重置表单\n    resetForm() {\n      this.form = {\n        name: \"\",\n        homeTypeId: \"\",\n        price: 0,\n        description: \"\",\n        img: \"\"\n      };\n      this.imageUrl = \"\";\n      if (this.$refs.form) {\n        this.$refs.form.resetFields();\n      }\n    }\n  },\n  watch: {\n    dialogVisible(val) {\n      if (!val) {\n        this.resetForm();\n      }\n    }\n  }\n};\n</script>\n\n<style scoped>\n.modern-form {\n  padding: 10px 10px;\n}\n\n.modern-form .el-form-item {\n  margin-bottom: 16px;\n}\n\n.modern-form .el-form-item__label {\n  font-weight: 500;\n  color: #606266;\n  font-size: 14px;\n}\n\n.field-full {\n  width: 100%;\n}\n\n.modern-dialog .el-select {\n  width: 100%;\n}\n\n.fixed-dialog >>> .el-dialog {\n  margin: 5vh auto !important;\n  position: relative;\n  top: auto;\n  left: auto;\n  transform: none !important;\n}\n\n.fixed-dialog >>> .el-dialog__wrapper {\n  overflow: auto !important;\n}\n\n.fixed-dialog >>> .el-dialog__body {\n  padding: 15px 20px;\n  overflow: visible;\n  max-height: none;\n}\n\n.avatar-uploader >>> .el-upload {\n  border: 1px dashed #d9d9d9;\n  border-radius: 6px;\n  cursor: pointer;\n  position: relative;\n  overflow: hidden;\n  transition: all 0.3s;\n}\n\n.avatar-uploader >>> .el-upload:hover {\n  border-color: #409eff;\n}\n\n.avatar-uploader-icon {\n  font-size: 24px;\n  color: #8c939d;\n  width: 120px;\n  height: 120px;\n  line-height: 120px;\n  text-align: center;\n}\n\n.avatar {\n  width: 120px;\n  height: 120px;\n  display: block;\n  object-fit: cover;\n}\n\n.upload-tip {\n  font-size: 12px;\n  color: #909399;\n  margin-top: 8px;\n  line-height: 1.5;\n}\n\n.modern-dialog-footer {\n  text-align: right;\n  padding-top: 10px;\n}\n\n.btn-cancel {\n  background: #e6a23c;\n  border-color: #e6a23c;\n  color: #ffffff;\n}\n\n.btn-cancel:hover {\n  background: #ebb563;\n  border-color: #ebb563;\n  color: #ffffff;\n}\n\n.btn-submit {\n  background: #409eff;\n  border-color: #409eff;\n  color: #ffffff;\n}\n\n.btn-submit:hover {\n  background: #66b1ff;\n  border-color: #66b1ff;\n}\n\n.fixed-dialog >>> .el-dialog__body::-webkit-scrollbar {\n  width: 6px;\n}\n\n.fixed-dialog >>> .el-dialog__body::-webkit-scrollbar-track {\n  background: #f5f5f5;\n  border-radius: 3px;\n}\n\n.fixed-dialog >>> .el-dialog__body::-webkit-scrollbar-thumb {\n  background: #c0c4cc;\n  border-radius: 3px;\n}\n\n.fixed-dialog >>> .el-dialog__body::-webkit-scrollbar-thumb:hover {\n  background: #909399;\n}\n</style>\n\n"],"sourceRoot":"src/views/home"}]}
\",\n        text: \"rgba(148,163,184,0.85)\",\n        activeText: \"#60a5fa\"\n      },\n      // SSE连接对象\n      eventSource: null\n    };\n  },\n  methods: {\n    logout: function logout() {\n      var _this = this;\n\n      this.$confirm('您确定要退出吗?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(function () {\n        // 关闭SSE连接\n        if (_this.eventSource) {\n          _this.eventSource.close();\n\n          _this.eventSource = null;\n        }\n\n        sessionStorage.clear();\n\n        _this.$router.push(\"/login\");\n      });\n    },\n    updatePassword: function updatePassword() {\n      this.$refs.update.dialogVisible = true;\n    },\n    // 构建菜单树形结构\n    buildMenuTree: function buildMenuTree(menus) {\n      // 找出所有父级菜单（parent_id为0或NULL）\n      var parents = menus.filter(function (menu) {\n        return !menu.parentId || menu.parentId === 0;\n      }); // 为每个父级菜单找到对应的子菜单\n\n      parents.forEach(function (parent) {\n        parent.children = menus.filter(function (menu) {\n          return menu.parentId === parent.id;\n        });\n      });\n      return parents;\n    },\n    // 根据菜单名称获取对应图标\n    getMenuIcon: function getMenuIcon(name) {\n      var iconMap = {\n        '管理员管理': 'el-icon-user-solid',\n        '社区数据': 'el-icon-data-analysis',\n        '社区信息管理': 'el-icon-office-building',\n        '用户管理': 'el-icon-user',\n        '配送员管理': 'el-icon-s-custom',\n        '社区天气': 'el-icon-partly-cloudy',\n        '家政订单管理': 'el-icon-s-order',\n        '代购订单管理': 'el-icon-shopping-cart-2',\n        '餐饮订单管理': 'el-icon-food',\n        '家政商品管理': 'el-icon-s-goods',\n        '代购商品管理': 'el-icon-goods',\n        '餐饮商品管理': 'el-icon-dish',\n        '社区从告管理': 'el-icon-bell',\n        '社区活动管理': 'el-icon-s-flag',\n        '订单管理': 'el-icon-s-order',\n        '社区管理': 'el-icon-office-building',\n        '商品管理': 'el-icon-s-goods',\n        'AI助手': 'el-icon-magic-stick',\n        '智能助手': 'el-icon-magic-stick',\n        'AI问答': 'el-icon-magic-stick'\n      };\n      return iconMap[name] || 'el-icon-menu';\n    },\n    // 初始化订单通知SSE连接\n    initOrderNotification: function initOrderNotification() {\n      var _this2 = this;\n\n      var token = sessionStorage.getItem('token');\n\n      if (!token) {\n        return;\n      } // 构建SSE连接URL（EventSource不支持自定义header，所以用URL参数传递token）\n\n\n      var baseURL = this.$http.defaults.baseURL.replace(/\\/$/, ''); // 移除末尾的斜杠\n\n      var url = \"\".concat(baseURL, \"/api/notification/order/stream?token=\").concat(token); // 建立SSE连接\n\n      this.eventSource = new EventSource(url); // 监听新订单事件\n\n      this.eventSource.addEventListener('newOrder', function (event) {\n        try {\n          var result = JSON.parse(event.data);\n\n          if (result.code === 200) {\n            var order = result.data;\n            console.log('收到新订单：', order); // 显示Element UI通知\n\n            _this2.$notify({\n              title: '新订单提醒',\n              message: \"\\u8BA2\\u5355\\u53F7\\uFF1A\".concat(order.id, \"\\uFF0C\\u91D1\\u989D\\uFF1A\\xA5\").concat(order.amount),\n              type: 'success',\n              duration: 5000,\n              position: 'top-right',\n              onClick: function onClick() {\n                // 点击通知后跳转到对应订单列表\n                _this2.navigateToOrderList(order);\n              }\n            }); // 显示浏览器原生通知\n\n\n            _this2.showBrowserNotification(order); // 如果当前在订单列表页面，刷新列表\n\n\n            _this2.refreshOrderListIfNeeded();\n          }\n        } catch (error) {\n          console.error('解析订单通知失败：', error);\n        }\n      }); // 连接打开\n\n      this.eventSource.onopen = function () {\n        console.log('订单通知SSE连接已建立');\n      }; // 连接错误（会自动重连）\n\n\n      this.eventSource.onerror = function (error) {\n        console.error('订单通知SSE连接错误：', error); // 如果连接关闭，尝试重新连接\n\n        if (_this2.eventSource && _this2.eventSource.readyState === EventSource.CLOSED) {\n          console.log('SSE连接已关闭，5秒后尝试重连...');\n          setTimeout(function () {\n            if (sessionStorage.getItem('token')) {\n              _this2.initOrderNotification();\n            }\n          }, 5000);\n        }\n      };\n    },\n    // 显示浏览器原生通知\n    showBrowserNotification: function showBrowserNotification(order) {\n      if ('Notification' in window) {\n        if (Notification.permission === 'granted') {\n          new Notification('新订单提醒', {\n            body: \"\\u8BA2\\u5355\\u53F7\\uFF1A\".concat(order.id, \"\\uFF0C\\u91D1\\u989D\\uFF1A\\xA5\").concat(order.amount, \"\\u5143\"),\n            icon: '/favicon.ico',\n            tag: \"order-\".concat(order.id) // 相同tag的通知会被替换\n\n          });\n        } else if (Notification.permission !== 'denied') {\n          // 请求通知权限\n          Notification.requestPermission().then(function (permission) {\n            if (permission === 'granted') {\n              new Notification('新订单提醒', {\n                body: \"\\u8BA2\\u5355\\u53F7\\uFF1A\".concat(order.id, \"\\uFF0C\\u91D1\\u989D\\uFF1A\\xA5\").concat(order.amount, \"\\u5143\"),\n                icon: '/favicon.ico'\n              });\n            }\n          });\n        }\n      }\n    },\n    // 根据订单类型跳转到对应订单列表\n    navigateToOrderList: function navigateToOrderList(order) {\n      // 根据订单类型判断跳转到哪个列表\n      // 假设order.type.id表示订单类型：1-餐饮，2-代购，3-家政\n      if (order.type && order.type.id) {\n        var typeId = order.type.id;\n\n        if (typeId === 1) {\n          this.$router.push('/eatList');\n        } else if (typeId === 2) {\n          this.$router.push('/purchaseList');\n        } else if (typeId === 3) {\n          this.$router.push('/homeList');\n        }\n      }\n    },\n    // 如果当前在订单列表页面，刷新列表\n    refreshOrderListIfNeeded: function refreshOrderListIfNeeded() {\n      var _this3 = this;\n\n      var currentPath = this.$route.path;\n\n      if (currentPath === '/eatList' || currentPath === '/purchaseList' || currentPath === '/homeList') {\n        // 通过事件总线通知子组件刷新\n        this.$nextTick(function () {\n          // 触发路由刷新，让子组件重新加载数据\n          _this3.$forceUpdate();\n        });\n      }\n    }\n  },\n  mounted: function mounted() {\n    var _this4 = this;\n\n    this.account = sessionStorage.getItem(\"account\");\n    this.currentMenu = this.$route.path === '/main' ? '智慧社区管理后台' : ''; // 建立订单通知SSE连接\n\n    this.initOrderNotification(); //登录成功后,向后端发送请求,查询管理员对应菜单\n\n    this.$http.get(\"api/menuCtl/menus\").then(function (resp) {\n      _this4.menus = resp.data.data;\n      console.log(\"原始菜单数据:\", _this4.menus); // 构建菜单树（包含所有父级菜单）\n\n      _this4.parentMenus = _this4.buildMenuTree(_this4.menus);\n      console.log(\"菜单树结构:\", _this4.parentMenus); // 设置默认展开的父级菜单（展开所有有子级的父级菜单）\n\n      _this4.defaultOpeneds = _this4.parentMenus.filter(function (parent) {\n        return parent.children && parent.children.length > 0;\n      }).map(function (parent) {\n        return String(parent.id);\n      });\n\n      var activeMenu = _this4.menus.find(function (m) {\n        return m.url === _this4.$route.path;\n      });\n\n      _this4.currentMenu = activeMenu ? activeMenu.name : '智慧社区管理后台';\n    });\n  },\n  // 组件销毁时关闭SSE连接\n  beforeDestroy: function beforeDestroy() {\n    if (this.eventSource) {\n      this.eventSource.close();\n      this.eventSource = null;\n      console.log('SSE连接已关闭');\n    }\n  },\n  watch: {\n    $route: function $route(to) {\n      // 更新当前菜单名称\n      var path = to.path;\n      var menu = this.menus.find(function (m) {\n        return m.url === path;\n      });\n      this.currentMenu = menu ? menu.name : '';\n    }\n  }\n};",{"version":3,"sources":["Main.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAiGA,OAAA,MAAA;AACA,eAAA;AACA,EAAA,UAAA,EAAA;AACA,IAAA,MAAA,EAAA;AADA,GADA;AAIA,EAAA,IAJA,kBAIA;AACA,WAAA;AACA,MAAA,OAAA,EAAA,EADA;AAEA,MAAA,KAAA,EAAA,EAFA;AAGA,MAAA,WAAA,EAAA,EAHA;AAIA,MAAA,cAAA,EAAA,EAJA;AAKA,MAAA,WAAA,EAAA,EALA;AAMA,MAAA,SAAA,E
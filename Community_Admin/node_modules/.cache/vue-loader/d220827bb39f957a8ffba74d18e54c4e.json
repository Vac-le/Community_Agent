  </div>\n          </el-col>\n        </el-row>\n      </div>\n    </div>\n\n    <!-- 用户信息和配送员信息 -->\n    <el-row :gutter=\"16\">\n      <!-- 用户信息 -->\n      <el-col :span=\"12\">\n        <div class=\"info-card\">\n          <div class=\"card-header\">\n            <i class=\"el-icon-user\"></i>\n            <span>下单用户</span>\n          </div>\n          <div class=\"card-body\">\n            <div class=\"info-row\">\n              <span class=\"label\">用户姓名：</span>\n              <span class=\"value\">{{ orderInfo.user ? orderInfo.user.name : '-' }}</span>\n            </div>\n          </div>\n        </div>\n      </el-col>\n\n      <!-- 配送员/服务人员信息 -->\n      <el-col :span=\"12\">\n        <div class=\"info-card\" v-if=\"orderInfo.send && orderInfo.orderStatus >= 1\">\n          <div class=\"card-header\">\n            <i class=\"el-icon-service\"></i>\n            <span>服务人员</span>\n          </div>\n          <div class=\"card-body\">\n            <div class=\"info-row\">\n              <span class=\"label\">服务人员：</span>\n              <span class=\"value\">{{ orderInfo.send.name || '-' }}</span>\n            </div>\n            <div class=\"info-row\">\n              <span class=\"label\">联系电话：</span>\n              <span class=\"value\">{{ orderInfo.send.phone || '-' }}</span>\n            </div>\n          </div>\n        </div>\n        <div class=\"info-card\" v-else>\n          <div class=\"card-header\">\n            <i class=\"el-icon-service\"></i>\n            <span>服务人员</span>\n          </div>\n          <div class=\"card-body\">\n            <div class=\"info-row\">\n              <span class=\"value\" style=\"color: #909399;\">暂未分配服务人员</span>\n            </div>\n          </div>\n        </div>\n      </el-col>\n    </el-row>\n\n    <!-- 家政服务信息 -->\n    <div class=\"info-card\">\n      <div class=\"card-header\">\n        <i class=\"el-icon-s-home\"></i>\n        <span>服务项目</span>\n      </div>\n      <div class=\"card-body\">\n        <div v-i